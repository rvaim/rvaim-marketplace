{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/{{HOOK_SCRIPT_NAME}}.mjs",
            "timeout": 30,
            "statusMessage": "正在检查"
          }
        ]
      }
    ]
  }
}
