{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "rvaim-marketplace",
  "version": "1.0.10",
  "description": "rvaim 的个人 Claude Code 插件市场，用于沉淀个人开发规则、代码迁移规范、审查习惯和自动化工作流。",
  "owner": {
    "name": "rvaim"
  },
  "plugins": [
    {
      "name": "arkts-harmony",
      "description": "鸿蒙 ArkTS / TypeScript 迁移规则、适配案例、高性能编程建议、HarmonyOS/OpenHarmony 开发文档查阅和自动后置检查。",
      "version": "1.0.2",
      "author": {
        "name": "rvaim"
      },
      "homepage": "https://github.com/rvaim/rvaim-marketplace/blob/main/plugins/arkts-harmony/README.md",
      "repository": "https://github.com/rvaim/arkts-harmony",
      "keywords": [
        "arkts",
        "harmonyos",
        "openharmony",
        "typescript",
        "migration",
        "deveco",
        "arkui",
        "code-review"
      ],
      "category": "Development",
      "tags": [
        "arkts",
        "harmonyos",
        "typescript",
        "migration",
        "code-review",
        "api-reference",
        "documentation"
      ],
      "source": "./plugins/arkts-harmony",
      "strict": true
    },
    {
      "name": "plugin-creator",
      "description": "创建、审查和维护 Codex / Claude Code 双平台插件的中文开发辅助插件。",
      "version": "1.0.2",
      "author": {
        "name": "rvaim"
      },
      "homepage": "https://github.com/rvaim/rvaim-marketplace/blob/main/plugins/plugin-creator/README.md",
      "repository": "https://github.com/rvaim/plugin-creator",
      "keywords": [
        "codex",
        "claude-code",
        "dual-platform",
        "plugin",
        "plugin-authoring",
        "skill",
        "marketplace",
        "manifest"
      ],
      "category": "Development",
      "tags": [
        "codex",
        "claude-code",
        "dual-platform",
        "skills",
        "manifest"
      ],
      "source": "./plugins/plugin-creator",
      "strict": true
    },
    {
      "name": "agent-worker",
      "description": "通过 agent-worker-mcp 把复杂任务委托给 Claude Code 等 worker agent，主 agent 只负责规划、审查和打回修改。",
      "version": "0.1.8",
      "author": {
        "name": "rvaim"
      },
      "homepage": "https://github.com/rvaim/rvaim-marketplace",
      "repository": "https://github.com/rvaim/rvaim-marketplace",
      "keywords": [
        "agent-worker",
        "mcp",
        "subagent",
        "delegation",
        "claude-code",
        "acpx",
        "reviewer",
        "token-saving"
      ],
      "category": "Development",
      "tags": [
        "agent-worker",
        "mcp",
        "subagent",
        "delegation",
        "reviewer",
        "token-saving"
      ],
      "source": {
        "source": "relative",
        "path": "./plugins/agent-worker"
      },
      "strict": true
    }
  ]
}
